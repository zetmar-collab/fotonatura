{
  "name": "fotonatura",
  "productName": "FotoNatura",
  "version": "1.0.0",
  "description": "Automatyczny retusz zdjęć dla każdego",
  "author": { "name": "Marek Zettel" },
  "homepage": "https://fotonatura.pl",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icons": "node create-icons.js",
    "manual": "node build-manual.js",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "dist": "node create-icons.js && node build-manual.js && electron-builder --linux && electron-builder --win"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "pdfkit": "^0.17.2",
    "png-to-ico": "^3.0.1",
    "pngjs": "^7.0.0"
  },
  "dependencies": {
    "heic-convert": "^2.1.0"
  },
  "build": {
    "appId": "pl.fotonatura.app",
    "productName": "FotoNatura",
    "copyright": "Copyright © 2024 Marek Zettel",
    "directories": { "output": "dist", "buildResources": "assets" },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "!renderer/**/*.map"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ],
      "category": "Graphics",
      "description": "Automatyczny retusz zdjęć dla każdego",
      "maintainer": "Marek Zettel"
    },
    "mac": {
      "icon": "assets/icon.icns",
      "target": [ { "target": "dmg" } ],
      "category": "public.app-category.graphics-and-design"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FotoNatura",
      "language": "1045",
      "include": "nsis/customInstaller.nsh"
    },
    "deb": {
      "depends": ["libgtk-3-0", "libnotify4", "libnss3", "libxss1", "libxtst6", "xdg-utils"],
      "afterInstall": "scripts/after-install.sh",
      "afterRemove": "scripts/after-remove.sh"
    }
  }
}
